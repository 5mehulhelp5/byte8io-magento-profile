<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="byte8_profile_entity" resource="default" engine="innodb">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="type_id" nullable="true" length="64"
                comment="Type ID"/>
        <column xsi:type="varchar" name="name" nullable="true" length="64"
                comment="Name"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="BYTE8_PROFILE_ENTITY_TYPE_ID">
            <column name="type_id"/>
        </constraint>
    </table>
    <table name="byte8_profile_config" resource="default" engine="innodb">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="int" name="parent_id" padding="10" unsigned="true" nullable="true" identity="false"
                comment="Parent ID"/>
        <column xsi:type="varchar" name="scope" nullable="false" length="8" default="default"
                comment="Scope"/>
        <column xsi:type="int" name="scope_id" padding="11" unsigned="false" nullable="false" identity="false" default="0"
                comment="Scope ID"/>
        <column xsi:type="varchar" name="path" nullable="false" length="255" default="general"
                comment="Path"/>
        <column xsi:type="longtext" name="value" nullable="true"
                comment="Value"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="BYTE8_PROFILE_CONFIG_PARENT_ID_BYTE8_PROFILE_ENTITY_ENTITY_ID"
                    table="byte8_profile_config" column="parent_id"
                    referenceTable="byte8_profile_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <constraint xsi:type="unique" referenceId="BYTE8_PROFILE_CONFIG_PARENT_ID_SCOPE_SCOPE_ID_PATH">
            <column name="parent_id"/>
            <column name="scope"/>
            <column name="scope_id"/>
            <column name="path"/>
        </constraint>
    </table>
    <table name="byte8_profile_history" resource="default" engine="innodb">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="int" name="parent_id" padding="10" unsigned="true" nullable="true" identity="false"
                comment="Parent ID"/>
        <column xsi:type="varchar" name="status" nullable="true" length="16"
                comment="Status"/>
        <column xsi:type="varchar" name="type_id" nullable="true" length="128"
                comment="Type ID"/>
        <column xsi:type="longtext" name="message" nullable="true"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="BYTE8_PROFILE_HISTORY_PARENT_ID_BYTE8_PROFILE_ENTITY_ENTITY_ID"
                    table="byte8_profile_history" column="parent_id"
                    referenceTable="byte8_profile_entity" referenceColumn="entity_id"
                    onDelete="CASCADE"/>
        <index referenceId="BYTE8_PROFILE_HISTORY_TYPE_ID" indexType="btree">
            <column name="type_id"/>
        </index>
        <index referenceId="BYTE8_PROFILE_HISTORY_CREATED_AT" indexType="btree">
            <column name="created_at"/>
        </index>
    </table>
    <table name="byte8_profile_queue" resource="default" engine="innodb" comment="Profile Queue">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="subject_entity_id" nullable="true" length="64"
                comment="Subject Entity ID"/>
        <column xsi:type="varchar" name="subject_type_id" nullable="true" length="64"
                comment="Subject Type ID"/>
        <column xsi:type="varchar" name="status" nullable="true" length="16"
                comment="Status"/>
        <column xsi:type="longtext" name="metadata" nullable="true"
                comment="Metadata"/>
        <column xsi:type="longtext" name="message" nullable="true"
                comment="Message"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="BYTE8_PROFILE_QUEUE_SUBJECT_ENTITY_ID_SUBJECT_TYPE_ID">
            <column name="subject_entity_id"/>
            <column name="subject_type_id"/>
        </constraint>
    </table>
    <table name="byte8_profile_schedule" resource="default" engine="innodb">
        <column xsi:type="int" name="entity_id" padding="10" unsigned="true" nullable="false" identity="true"
                comment="Entity ID"/>
        <column xsi:type="varchar" name="type_id" nullable="true" length="64"
                comment="Type ID"/>
        <column xsi:type="boolean" name="status" nullable="false" default="0"
                comment="Status"/>
        <column xsi:type="varchar" name="name" nullable="true" length="64"
                comment="Name"/>
        <column xsi:type="varchar" name="cron_expression" nullable="true" length="16"
                comment="Cron Expression"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Updated At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="BYTE8_PROFILE_SCHEDULE_TYPE_ID">
            <column name="type_id"/>
        </constraint>
    </table>
</schema>
