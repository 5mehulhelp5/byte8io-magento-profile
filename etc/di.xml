        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="profile_config_export" xsi:type="object">Byte8\Profile\Console\Command\ExportConfigData</item>
                <item name="profile_config_import" xsi:type="object">Byte8\Profile\Console\Command\ImportConfigData</item>
                <item name="profile_data_purge" xsi:type="object">Byte8\Profile\Console\Command\PurgeProfileDataCommand</item>
            </argument>
        </arguments>
    </type>
