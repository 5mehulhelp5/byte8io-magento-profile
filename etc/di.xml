    <preference for="Byte8\Profile\Model\GetProfileTypeIdInterface" type="Byte8\Profile\Model\GetProfileTypeId"/>
    <preference for="Byte8\Profile\Model\ServiceAbstract\ProcessorGuardInterface" type="Byte8\Profile\Model\ServiceAbstract\ProcessorGuard"/>
    <!-- profile config ::: interface | repository | management -->
    <preference for="Byte8\Profile\Api\Data\ConfigInterface" type="Byte8\Profile\Model\Config"/>
    <preference for="Byte8\Profile\Api\Data\ConfigSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
