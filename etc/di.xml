    <preference for="Byte8\Profile\Api\HistoryManagementInterface" type="Byte8\Profile\Model\HistoryManagement"/>

    <!-- Queue entity ::: model interface ::: management interfaces -->
    <preference for="Byte8\Profile\Api\Data\QueueInterface" type="Byte8\Profile\Model\Queue"/>
    <preference for="Byte8\Profile\Api\Data\QueueSearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
