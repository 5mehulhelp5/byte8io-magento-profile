<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- profile ::: interface | repository | management -->
    <preference for="Byte8\Profile\Api\Data\ProfileInterface" type="Byte8\Profile\Model\Profile"/>
    <preference for="Byte8\Profile\Api\Data\Profile\SearchResultsInterface" type="Magento\Framework\Api\SearchResults"/>
