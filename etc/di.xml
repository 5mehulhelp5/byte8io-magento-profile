    <virtualType name="Byte8\ProfileSchedule\Model\ResourceModel\Grid\Collection" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">byte8_profile_schedule</argument>
            <argument name="resourceModel" xsi:type="string">Byte8\ProfileSchedule\Model\ResourceModel\Schedule</argument>
        </arguments>
    </virtualType>
    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="byte8_profile_schedule_listing_data_source" xsi:type="string">Byte8\ProfileSchedule\Model\ResourceModel\Grid\Collection</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\Model\Entity\RepositoryFactory">
        <arguments>
            <argument name="entities" xsi:type="array">
                <item name="Byte8\ProfileSchedule\Api\Data\ScheduleInterface" xsi:type="string">Byte8\ProfileSchedule\Api\ScheduleRepositoryInterface</item>
            </argument>
        </arguments>
    </type>
    <type name="Magento\Framework\EntityManager\MetadataPool">
        <arguments>
            <argument name="metadata" xsi:type="array">
                <item name="Byte8\ProfileSchedule\Api\Data\ScheduleInterface" xsi:type="array">
                    <item name="entityTableName" xsi:type="string">byte8_profile_schedule</item>
                    <item name="identifierField" xsi:type="string">entity_id</item>
                </item>
            </argument>
        </arguments>
    </type>
    <!-- profile config instance ::: schedule -->
    <preference for="Byte8\ProfileSchedule\Model\Config\ScheduleConfigInterface" type="Byte8\ProfileSchedule\Model\Config\ScheduleConfig"/>
    <!-- Logger -->
    <virtualType name="Byte8\ProfileSchedule\VirtualStreamHandler" type="Magento\Framework\Logger\Handler\Base">
        <arguments>
            <argument name="fileName" xsi:type="string">var/log/byte8/scheduler.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="Byte8\ProfileSchedule\VirtualRotationStreamHandler" type="Byte8\Core\Logger\Handler\RotationSteamHandler">
        <arguments>
            <argument name="fileName" xsi:type="string">var/log/byte8/scheduler.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="Byte8\ProfileSchedule\VirtualLogger" type="Byte8\Core\Logger\LogProcessor">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="debug" xsi:type="object">Byte8\ProfileSchedule\VirtualStreamHandler</item>
                <item name="rotation_debug" xsi:type="object">Byte8\ProfileSchedule\VirtualRotationStreamHandler</item>
                <item name="mail" xsi:type="object">Byte8\Core\Logger\Handler\MailStreamHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <type name="Byte8\ProfileSchedule\Model\ScheduleProcessor">
        <arguments>
            <argument name="logger" xsi:type="object">Byte8\ProfileSchedule\VirtualLogger</argument>
        </arguments>
    </type>

