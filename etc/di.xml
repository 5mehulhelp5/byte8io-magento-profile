    <preference for="Byte8\Profile\Model\Config\Type\EventConfigInterface" type="Byte8\Profile\Model\Config\Type\EventConfig"/>
    <preference for="Byte8\Profile\Model\Config\Type\LogConfigInterface" type="Byte8\Profile\Model\Config\Type\LogConfig"/>
    <!-- Service Preferences -->
    <preference for="Byte8\Profile\Api\Service\PurgeProfileDataInterface" type="Byte8\Profile\Model\Service\PurgeProfileData"/>
    <!-- profile types -->
    <preference for="Byte8\Profile\Model\ProfileTypes\ConfigInterface" type="Byte8\Profile\Model\ProfileTypes\Config"/>
    <virtualType name="Byte8\Profile\Model\ProfileTypes\Config\Data" type="Magento\Framework\Config\Data">
        <arguments>
            <argument name="reader" xsi:type="object">Byte8\Profile\Model\ProfileTypes\Config\Reader\Virtual</argument>
            <argument name="cacheId" xsi:type="string">profile_type_config</argument>
        </arguments>
    </virtualType>
    <virtualType name="Byte8\Profile\Model\ProfileTypes\Config\Reader\Virtual" type="Magento\Framework\Config\Reader\Filesystem">
        <arguments>
            <argument name="converter" xsi:type="object">Byte8\Profile\Model\ProfileTypes\Config\Converter</argument>
            <argument name="schemaLocator" xsi:type="object">Byte8\Profile\Model\ProfileTypes\Config\SchemaLocator\Virtual</argument>
            <argument name="fileName" xsi:type="string">profile_type.xml</argument>
            <argument name="idAttributes" xsi:type="array">
                <item name="/config/profile" xsi:type="string">typeId</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="Byte8\Profile\Model\ProfileTypes\Config\SchemaLocator\Virtual" type="Magento\Framework\Config\GenericSchemaLocator">
        <arguments>
            <argument name="moduleName" xsi:type="string">Byte8_Profile</argument>
            <argument name="schema" xsi:type="string">profile_type.xsd</argument>
        </arguments>
    </virtualType>
    <type name="Byte8\Profile\Model\ProfileTypes\Config">
        <arguments>
            <argument name="config" xsi:type="object">Byte8\Profile\Model\ProfileTypes\Config\Data</argument>
        </arguments>
    </type>

    <!-- profile history ::: interface | repository | management -->
    <preference for="Byte8\Profile\Api\Data\HistoryInterface" type="Byte8\Profile\Model\History"/>
